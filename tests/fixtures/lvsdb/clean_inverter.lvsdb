#%lvsdb-klayout

# Layout
layout(
 top(INVERTER)
 unit(0.001)

 # Mask layers
 layer(l3 'NWELL (1/0)')
 layer(l4 'POLY (5/0)')
 layer(l8 'CONTACT (6/0)')
 layer(l9 'METAL1 (7/0)')

 # Connectivity
 connect(l3 l3)
 connect(l4 l4 l8)
 connect(l8 l4 l8 l9)
 connect(l9 l8 l9)

 # Global nets
 global(l3 NWELL)

 # Device classes
 class(PMOS MOS4)
 class(NMOS MOS4)

 # Circuit section
 circuit(INVERTER

  # Nets
  net(1 name(IN)
   rect(l4 (900 50) (250 1050))
  )
  net(2 name(VSS)
   rect(l9 (0 0) (2000 500))
  )
  net(3 name(VDD)
   rect(l9 (0 5650) (2000 500))
  )
  net(4 name(OUT)
   rect(l9 (1500 2500) (500 1200))
  )

  # Devices
  device(1 PMOS
   name($1)
   param(L 0.25)
   param(W 1.5)
   param(AS 0.675)
   param(AD 0.675)
   terminal(S 4)
   terminal(G 1)
   terminal(D 3)
   terminal(B 3)
  )
  device(2 NMOS
   name($2)
   param(L 0.25)
   param(W 0.9)
   param(AS 0.405)
   param(AD 0.405)
   terminal(S 2)
   terminal(G 1)
   terminal(D 4)
   terminal(B 2)
  )

 )
)

# Reference netlist
reference(

 # Device classes
 class(PMOS MOS4)
 class(NMOS MOS4)

 # Circuit section
 circuit(INVERTER

  # Nets
  net(1 name(VSS))
  net(2 name(IN))
  net(3 name(OUT))
  net(4 name(VDD))

  # Pins
  pin(0 name(VSS))
  pin(1 name(IN))
  pin(2 name(OUT))
  pin(3 name(VDD))

  # Devices
  device(1 PMOS
   name(P)
   param(L 0.25)
   param(W 1.5)
   param(AS 0)
   param(AD 0)
   terminal(S 3)
   terminal(G 2)
   terminal(D 4)
   terminal(B 4)
  )
  device(2 NMOS
   name(N)
   param(L 0.25)
   param(W 0.9)
   param(AS 0)
   param(AD 0)
   terminal(S 1)
   terminal(G 2)
   terminal(D 3)
   terminal(B 1)
  )

 )
)

# Cross reference
xref(
 circuit(INVERTER INVERTER match
  xref(
   net(1 2 match)
   net(2 1 match)
   net(3 4 match)
   net(4 3 match)
   pin(() 0 match)
   pin(() 1 match)
   pin(() 2 match)
   pin(() 3 match)
   device(1 1 match)
   device(2 2 match)
  )
 )
)
