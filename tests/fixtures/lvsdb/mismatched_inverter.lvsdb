#%lvsdb-klayout

# Layout — has an extra NMOS device and an extra net compared to schematic
layout(
 top(INVERTER)
 unit(0.001)

 # Mask layers
 layer(l3 'NWELL (1/0)')
 layer(l4 'POLY (5/0)')
 layer(l8 'CONTACT (6/0)')
 layer(l9 'METAL1 (7/0)')

 # Device classes
 class(PMOS MOS4)
 class(NMOS MOS4)

 # Circuit section
 circuit(INVERTER

  # Nets
  net(1 name(IN)
   rect(l4 (900 50) (250 1050))
  )
  net(2 name(VSS)
   rect(l9 (0 0) (2000 500))
  )
  net(3 name(VDD)
   rect(l9 (0 5650) (2000 500))
  )
  net(4 name(OUT)
   rect(l9 (1500 2500) (500 1200))
  )
  net(5 name(EXTRA_NET)
   rect(l9 (500 3000) (300 300))
  )

  # Devices — includes an extra NMOS not in schematic
  device(1 PMOS
   name($1)
   param(L 0.25)
   param(W 1.5)
   terminal(S 4)
   terminal(G 1)
   terminal(D 3)
   terminal(B 3)
  )
  device(2 NMOS
   name($2)
   param(L 0.25)
   param(W 0.9)
   terminal(S 2)
   terminal(G 1)
   terminal(D 4)
   terminal(B 2)
  )
  device(3 NMOS
   name($3)
   param(L 0.50)
   param(W 0.9)
   terminal(S 2)
   terminal(G 4)
   terminal(D 5)
   terminal(B 2)
  )

 )
)

# Reference netlist — expects a resistor not in layout
reference(

 # Device classes
 class(PMOS MOS4)
 class(NMOS MOS4)
 class(RES RES)

 # Circuit section
 circuit(INVERTER

  # Nets
  net(1 name(VSS))
  net(2 name(IN))
  net(3 name(OUT))
  net(4 name(VDD))

  # Pins
  pin(0 name(VSS))
  pin(1 name(IN))
  pin(2 name(OUT))
  pin(3 name(VDD))

  # Devices
  device(1 PMOS
   name(P)
   param(L 0.25)
   param(W 1.5)
   terminal(S 3)
   terminal(G 2)
   terminal(D 4)
   terminal(B 4)
  )
  device(2 NMOS
   name(N)
   param(L 0.25)
   param(W 0.9)
   terminal(S 1)
   terminal(G 2)
   terminal(D 3)
   terminal(B 1)
  )
  device(3 RES
   name(R1)
   param(R 1000)
   param(L 10)
   param(W 1)
   terminal(A 3)
   terminal(B 4)
  )

 )
)

# Cross reference — nomatch: extra NMOS in layout, missing RES from layout, extra net
xref(
 circuit(INVERTER INVERTER nomatch
  xref(
   net(1 2 match)
   net(2 1 match)
   net(3 4 match)
   net(4 3 match)
   net(5 () nomatch)
   pin(() 0 match)
   pin(() 1 match)
   pin(() 2 match)
   pin(() 3 match)
   device(1 1 match)
   device(2 2 match)
   device(3 () nomatch)
   device(() 3 nomatch)
  )
 )
)
